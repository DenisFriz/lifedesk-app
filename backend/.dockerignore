# Dependencies — never copy into image; npm ci reinstalls from lock file
node_modules/

# Compiled output — builder stage regenerates this cleanly
dist/

# Environment files — secrets must never be baked into an image layer
.env
.env.*
*.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# VCS
.git/
.gitignore

# Editor / OS artifacts
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*~

# TypeScript build info (regenerated by tsc)
*.tsbuildinfo

# Docker files themselves (no need to COPY into image)
Dockerfile
docker-compose.yml
.dockerignore

# Markdown / docs
*.md
CLAUDE.md
QUICKSTART.md
README.md

# Test artifacts (if added later)
coverage/
